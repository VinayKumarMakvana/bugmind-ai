# BugMind AI Backend Environment Variables - Production Template
# Copy this file to .env in your production environment and fill in the values.

# -----------------------------
# CORE AI SERVICES
# -----------------------------
# OpenAI API Key for generating code reviews and chat responses
OPENAI_API_KEY="sk-..."

# -----------------------------
# GITHUB APP INTEGRATION
# -----------------------------
# Required for the app to interact with repositories
GITHUB_CLIENT_ID="Iv..."
GITHUB_APP_ID="123456"
GITHUB_WEBHOOK_SECRET="your_webhook_secret_here"
GITHUB_API_BASE_URL="https://api.github.com"

# -----------------------------
# FRONTEND URL
# -----------------------------
# The live URL of your deployed frontend (e.g., https://bugmind.yourdomain.com)
FRONTEND_URL="https://bugmind.yourdomain.com"

# -----------------------------
# INFRASTRUCTURE (DATABASES)
# -----------------------------
# Redis (Used for background tasks and Celery)
# E.g., Upstash, Render Redis, etc.
REDIS_URL="rediss://default:password@host:port"

# Database (PostgreSQL recommended for production)
# E.g., Supabase, Neon DB, Railway
DATABASE_URL="postgresql://user:password@host:port/dbname"

# -----------------------------
# SECURITY
# -----------------------------
# A strong, randomly generated string for JWT and session security.
# Run `openssl rand -hex 32` to generate one.
SECRET_KEY="generate_a_strong_random_secret_string"
